{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "description": "Smarter job applications powered by AI - Generate tailored resumes and cover letters",
  "author": "Romain Julien",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "graphql:schema": "tsx --tsconfig ./tsconfig.json ./scripts/generate-graphql-schema.ts",
    "codegen:graphql": "pnpm graphql:schema && graphql-codegen --config codegen.ts",
    "codegen:check": "pnpm codegen:graphql && git diff --exit-code -- graphql/schema.graphql graphql/generated/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@next/env": "16.0.3",
    "@pothos/core": "^4.12.0",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.55.4",
    "@vercel/analytics": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "0.8.3",
    "framer-motion": "^12.23.26",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.18.0",
    "lucide-react": "^0.454.0",
    "next": "16.0.3",
    "next-auth": "5.0.0-beta.30",
    "postgres": "^3.4.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "styled-components": "^6.3.11",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/typed-document-node": "^6.1.6",
    "@graphql-codegen/typescript": "^4.0.9",
    "@graphql-codegen/typescript-operations": "^4.2.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.0",
    "graphql": "^16.9.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tsx": "^4.19.1",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.3"
  }
}
