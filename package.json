{
  "name": "apply-mate-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "ApplyMate web app (Next.js + in-app GraphQL API)",
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "graphql:codegen:web": "pnpm --filter web codegen:graphql",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "turbo run type-check lint && pnpm format:check",
    "cache:clear:next": "rm -rf apps/web/.next"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@eslint/json": "^1.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  }
}
